# ReelDigest server configuration
# Copy this file to .env and edit as needed.
# All values below are the defaults — only set what you want to override.

# --- Whisper (speech-to-text) ---
WHISPER_MODEL=tiny          # tiny | base | small | medium | large-v3

# --- Ollama (summarisation) ---
OLLAMA_MODEL=mistral        # any model you've pulled: mistral, phi3:mini, llama3.2, etc.
OLLAMA_HOST=http://localhost:11434
OLLAMA_NUM_GPU=0            # 0 = CPU-only (safe default); -1 = let Ollama decide

# --- OCR ---
OCR_LANG=en                 # comma-separated language codes, e.g. en,hi

# --- Frame sampling ---
FRAME_INTERVAL=2.0          # seconds between sampled frames
MAX_FRAMES=60               # max frames OCR'd per reel
DIFF_THRESHOLD=8.0          # skip frames more similar than this (0-255 scale)

# --- LLM input ---
MAX_CHARS=6000              # chars of transcript + OCR sent to the LLM

# --- Download ---
DOWNLOAD_ATTEMPTS=2
DOWNLOAD_TIMEOUT=30
RETRY_DELAY=2.0

# --- Instagram authentication (REQUIRED) ---
# Instagram now blocks anonymous downloads. Export cookies from a browser
# where you are logged in to Instagram, then set this path.
#
# How to export:
#   1. Install the "Get cookies.txt LOCALLY" extension in Chrome/Edge
#   2. Log in to instagram.com
#   3. Click the extension icon, select "instagram.com", export
#   4. Save the file as instagram_cookies.txt in this project folder
#   5. Set the path below (relative paths are from the project root)
#
INSTAGRAM_COOKIES_FILE=instagram_cookies.txt

# --- Telegram bot ---
TELEGRAM_TOKEN=             # get from @BotFather on Telegram (required to enable the bot)
TELEGRAM_ALLOWED_USERS=     # comma-separated user IDs, e.g. 123456789,987654321
                            # leave blank to allow anyone who finds the bot
                            # get your ID by messaging @userinfobot on Telegram

# --- Server ---
HOST=0.0.0.0               # 0.0.0.0 = reachable on LAN/Tailscale; 127.0.0.1 = local only
PORT=8000

# --- Job store ---
MAX_STORED_JOBS=200         # oldest done/failed jobs evicted beyond this limit
